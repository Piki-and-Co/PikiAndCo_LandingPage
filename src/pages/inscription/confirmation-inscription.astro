---
import BiumizLayout from '@/layouts/BiumizLayout.astro';
---

<BiumizLayout
  title="Inscription confirmée"
  description="Merci d'avoir rejoint la communauté Piki & Co !"
>
  <section style="padding: 8rem 5%; min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
    <div style="max-width: 32rem;">
      <div style="font-size: 4rem; margin-bottom: 1.5rem;">🎉</div>
      <h1>Merci d'avoir rejoint notre communauté !</h1>
      <p style="color: rgba(255,255,255,0.8); margin-top: 1.5rem; font-size: 1.1rem; line-height: 1.8;">
        Vous allez recevoir un e-mail vous permettant de confirmer votre adresse.
      </p>
      <a href="/" style="display: inline-block; margin-top: 2.5rem;" class="btn-primary">
        Retour à l'accueil
      </a>
    </div>
  </section>
</BiumizLayout>

---
import PikiCoLayout from '@/layouts/PikiCoLayout.astro';
---

<PikiCoLayout title="Accueil" description="Jouer, s'éveiller, s'accomplir. Accompagnez votre enfant dans le développement des compétences indispensables à sa future vie d'adulte.">
  <!-- Hero -->
  <section class="section" style="padding-top: 4rem;">
    <div class="container" style="text-align: center;">
      <img
        src="/assets/logo.png"
        alt="Piki & Co"
        style="height: 5rem; margin-bottom: 2rem;"
      />
      <h1>Jouer, s'éveiller, s'accomplir.</h1>
      <p style="font-size: 1.2rem; max-width: 42rem; margin: 1.5rem auto 2.5rem; color: var(--pikico-muted); line-height: 1.8;">
        Accompagnez votre enfant dans le développement des compétences psychosociales,
        socle de la santé mentale positive, grâce à une utilisation saine et intelligente du numérique.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/biumiz" class="btn btn-primary">Découvrir Biumiz</a>
        <a href="/blog" class="btn btn-outline">Notre blog</a>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="section section--tinted" id="mission">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: 1rem;">Notre mission</h2>
      <p style="text-align: center; max-width: 40rem; margin: 0 auto; color: var(--pikico-muted);">
        Piki & Co développe des outils pour accompagner les enfants dans l'acquisition
        des compétences psychosociales (CPS) — clés de leur épanouissement et de leur
        santé mentale future.
      </p>
    </div>
  </section>

  <!-- Partenaires -->
  <section class="section" id="partenaires">
    <div class="container" style="text-align: center;">
      <p style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--pikico-muted); margin-bottom: 2rem;">
        Ils nous font confiance
      </p>
      <!-- Les logos partenaires seront migrés ici -->
    </div>
  </section>
</PikiCoLayout>

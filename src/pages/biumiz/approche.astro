---
import BiumizLayout from '@/layouts/BiumizLayout.astro';

import { Image } from 'astro:assets';

import biumizSmile from '@assets/Biumiz_Smile.webp';
import tomAmazed from '@assets/Tom_Amazing.webp';
import tomLaugh from '@assets/Tom_Laugh.webp';

const ApprocheFaqSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
	{
      "@type": "Question",
      "name": "Les écrans, les jeux vidéo et les enfants : quelles recommandations ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pas d'écrans avant 3 ans. À partir de 3 ans, limiter à 1h maximum par jour. Choisir des contenus adaptés à la maturité cognitive et émotionnelle de l'enfant. Le jeu vidéo offre une expérience sensorielle et émotionnelle complète qui en fait un média puissant d'apprentissage, à condition d'une utilisation saine.",
      },
    },
    {
      "@type": "Question",
      "name": "Quels sont les bienfaits des jeux vidéo pour les enfants ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Les jeux vidéo permettent de développer : la curiosité, la créativité, la persévérance, la capacité d'élaboration de stratégie, la coopération, la prise de décision, l'attention, la résolution de problème, la littéracie numérique et le plurilinguisme.",
      },
    },
    {
      "@type": "Question",
      "name": "Qu'est-ce qu'une utilisation saine des jeux vidéo ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Limiter le temps d'écran (pas d'écran avant 3 ans, 1h max consécutive ensuite), veiller à ce que des activités alternatives soient disponibles, et utiliser le jeu comme sujet de conversation et d'échange en famille.",
      },
    }
	],
});
---
<BiumizLayout
		title="Notre approche" 
		description="Une toute nouvelle pédagogie issue de la recherche en sciences humaines"
		faqScema = {ApprocheFaqSchema}
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={ApprocheFaqSchema}/>
  	</Fragment>


	<!-- Notre approche -->
	<section class="section section--tinted" id="Approche">
		<div class="container">
			<p class="section-eyebrow">Les trois piliers de notre approche</p>
			<h2 class="section-heading">Comment ça marche ?</h2>
			<p class="section-lead">
			Issue d'une collaboration pérenne avec des laboratoires de recherche publique en sciences humaines, 
			notre approche innovante s'appuie sur trois piliers.
			</p>
			<div class="piliers-list">
				<div class="pilier-row">
					<div class="pilier-image">
						<Image src={biumizSmile} alt="S'ouvrir par les langues" 
						width={1061} height={1031} format="webp" />
					</div>
					<div class="pilier-content">
						<h3 class="pilier-title"><span class="pilier-number">1</span> S'ouvrir par les langues</h3>
						<p class="pilier-text">
							Les enfants bilingues sont avantagés dans leur développement cognitif, émotionnel et social... 
							A condition d'avoir développer les savoir-faire d'interaction et de communication*.
							<br/>Notre toute nouvelle pédagogie est expérientielle, culturelle et immersive. L'enfant apprend
							à interagir et à communiquer en anglais via des simulations du réel. 
						</p>
						<p class="quoting">* <a href="https://www.enfant-encyclopedie.com/deuxieme-langue/selon-experts/deuxieme-languebilinguisme-chez-les-jeunes-enfants-et-impacts-sur-le" target="_blank" rel="noopener noreferrer">
												Nicoladis, E. et al., 2016 </a>
						; <a href="https://pmc.ncbi.nlm.nih.gov/articles/PMC4791950/" target="_blank" rel="noopener noreferrer">
						Fan, S. P. et al. 2015</a></p>
					</div>
				</div>

				<div class="pilier-row pilier-row--reverse">
					<div class="pilier-image">
						<Image src={tomLaugh} alt="Apprendre par le jeu" 
						width={883} height={858} format="webp" />
					</div>
					<div class="pilier-content">
						<h3 class="pilier-title"><span class="pilier-number">2</span> Apprendre par le jeu</h3>
						<p class="pilier-text">
							Le jeu engage les sens et les émotions, ce qui favorise l'acquisition de nouvelles compétences.
							Il est donc le meilleur vecteur d'apprentissage*.
							<br/>Nos expériences ludiques sont calibrées 
							par tranche d'âge. 
							<br/>Aucune directive, uniquement du jeu. 
						</p>
						<p class="quoting">* Gee, J.P., 2007 ; Berry, V., 2012</p>

					</div>
				</div>
				<div class="pilier-row">
					<div class="pilier-image">
						<Image src={tomAmazed} alt="Le numérique au service du lien"
						width={1076} height={1073} format="webp" />
					</div>
					<div class="pilier-content">
						<h3 class="pilier-title"><span class="pilier-number">3</span> Le numérique au service du lien</h3>
						<p class="pilier-text">
							Le jeu vidéo pour l'immersion et la découverte des nouvelles notions, le jeu de société 
							pour la pratique dans le réel et le partage en famille.<br/>
							Le numérique comme vecteur d'interactions sociales, pas de remplacement.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>
	
	<section class="section faq" id="faq">
    <div class="container">
      <p class="section-eyebrow">Questions fréquentes</p>

      <details class="faq-parent">
        <summary>Les écrans, les jeux vidéo et les enfants : recommandations et points d'attention</summary>
        <p>Le jeu vidéo offre aux joueurs et joueuses une expérience complète, sensorielle et émotionnelle, ce qui en fait un média puissant d'apprentissage.</p>
        <p>Issus de différents documents officiels*, voici quelques points clefs à retenir :</p>
        <ul>
          <li>Pas d'écrans avant 3 ans,</li>
          <li>À partir de 3 ans, limiter le temps d'écran à 1h maximum par jour,</li>
          <li>Choisir des contenus adaptés à votre enfant vis-à-vis de sa maturité cognitive et émotionnelle.</li>
        </ul>
        <p>Il est important de garder à l'esprit que ce qui rend les écrans toxiques pour vos enfants est l'appauvrissement des interactions sociales qui en découlent. Si vous utilisez le contenu vidéo comme prétexte pour discuter et passer du temps ensemble, alors tout ira bien !</p>
		<p class="quoting">* Rapport remis à l'Élysée en avril 2024 
		<a href="https://www.elysee.fr/admin/upload/default/0001/16/fbec6abe9d9cc1bff3043d87b9f7951e62779b09.pdf"
		 target="_blank" rel="noopener noreferrer">Enfants et écrans, À la recherche du temps perdu"</a></p>
      </details>

      <details class="faq-parent">
        <summary>Quels sont les bienfaits des jeux vidéo ?</summary>
        <p>D'après les travaux en sciences humaines, voici quelques compétences que les jeux vidéo permettent de développer :</p>
        <ul>
          <li>La curiosité et la capacité à oser,</li>
          <li>La créativité, la persévérance,</li>
          <li>La capacité d'élaboration de stratégie,</li>
          <li>La coopération, l'esprit de communauté,</li>
          <li>La prise de décision, l'attention, le temps de réaction,</li>
          <li>La résolution de problème,</li>
          <li>La littéracie numérique,</li>
          <li>Le plurilinguisme et les langues étrangères.</li>
        </ul>
        <details class="faq-child">
          <summary>Pour aller plus loin</summary>
		  <p>Un article qui résume l'impact du jeu vidéo sur les enfants : 
		  <a href="https://www.pedagojeux.fr/sujets-sensibles/limpact-du-jeu-sur-la-psychologie-de-mon-enfant/" 
			 target="_blank" rel="noopener noreferrer">Échange entre PédaGojeux et Mickaël Stora, psychologue et psychanaliste.
		  </a></p>
        </details>
      </details>

      <details class="faq-parent">
        <summary>Concrètement, qu'est-ce qu'une "utilisation saine" des jeux vidéo ?</summary>
        <p>Pour que le jeu vidéo soit bénéfique, quelques habitudes simples sont à mettre en place pour toute la famille.</p>
        <h3>Limitez le temps passé sur un écran</h3>
        <p>En dessous de 3 ans, il est fortement recommandé d'interdire complètement l'écran. Ensuite, le temps sur écran doit rester occasionnel et ne pas dépasser une heure d'utilisation consécutive.</p>
        <h3>Veillez à ce que des activités alternatives soient toujours disponibles</h3>
        <p>Coloriage, jeux de construction, création artistique ou jeux dehors — il est important que votre enfant puisse s'amuser autrement qu'en jouant sur un écran.</p>
        <h3>Utilisez le jeu comme sujet de conversation et d'échange</h3>
        <p>Comme avec un film ou un livre, le jeu vidéo fournit des sujets de conversation pour alimenter les moments en famille.</p>
        <ul>
          <li>Quelle histoire raconte ton jeu ? Qui sont les personnages ?</li>
          <li>Quelles sont les règles de ton jeu ?</li>
          <li>Qu'est-ce que tu ressens quand tu joues ? Quand tu réussis ? Quand tu te trompes ?</li>
        </ul>
        <p>Quelques ressources utiles : <a href="https://pegi.info/fr/page/game-advice" target="_blank" rel="noopener noreferrer">PEGI</a>, <a href="https://www.mon-enfant-et-les-ecrans.fr/" target="_blank" rel="noopener noreferrer">Mon enfant et les écrans (UNAF)</a>.</p>
      </details>



</BiumizLayout>
<style>
	
	.section { 
		padding: var(--section-gap) 0; 
		background: var(--light-purple);
	}
	
	.section--tinted {
		background: linear-gradient(to bottom, var(--biumiz-bg-start), var(--biumiz-bg-end)) !important;
		color: var(--white) !important;
	}

	.section-eyebrow {
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 0.75rem;
	}

	.section-heading {
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		font-weight: 400;
		margin-bottom: 2rem;
	}

	.section-lead {
		text-align: center;
		max-width: 44rem;
		margin: 0 auto 3rem;
		font-size: 1.05rem;
		line-height: 1.8;
		opacity: 0.9;
	}

	.piliers-list {
		display: flex;
		flex-direction: column;
		gap: 4rem; /* Espace entre les lignes de piliers */
		width: 100%;
	}

	/* --- CHANGER DE CÔTÉ (GRID) --- */
	.pilier-row {
		display: grid;
		grid-template-columns: 1fr; /* 1 colonne par défaut sur mobile */
		gap: 2rem;
		align-items: center;
		text-align: center;
	}

	@media (min-width: 48rem) {
		.pilier-row {
			grid-template-columns: 1fr 1fr; /* 2 colonnes égales sur PC */
			text-align: left;
		}

		/* La magie du CSS : pour la deuxième ligne, on inverse l'ordre visuel */
		.pilier-row--reverse .pilier-image {
			order: 2;
		}

		.pilier-row--reverse .pilier-content {
			order: 1;
		}
	}

	.pilier-image {
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: visible !important; /* Force le contenu qui dépasse à rester visible */
		padding-bottom: 1rem; /* Donne un peu d'espace en bas pour le halo */
	}

	.pilier-image img {
		max-width: 22rem; /* Ajuste la taille des mascottes pour qu'elles restent élégantes */
		display: block;
		width: 100%; /* Occupe la largeur du wrapper */
		height: auto !important; /* Force le navigateur à recalculer la hauteur proportionnellement */
		object-fit: contain;
	}

	.pilier-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.pilier-title {
		font-family: var(--font-body); /* Montserrat ou sans-serif pour garder le style épuré de l'image */
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		justify-content: center; /* Centré sur mobile */
		gap: 0.75rem;
	}

	@media (min-width: 48rem) {
		.pilier-title {
		  justify-content: flex-start; /* Aligné à gauche sur PC */
		}
	}

	.pilier-number {
		background-color: var(--dark-yellow);
		color: black;
		font-size: 1rem;
		font-weight: 700;
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0; /* Empêche le rond de se déformer */
	}

	.pilier-text {
		font-size: 1.05rem;
		line-height: 1.7;
		max-width: 38rem;
		margin: 0 auto;
	}

	@media (min-width: 48rem) {
		.pilier-text {
		  margin: 0; /* Aligné au bord gauche sur PC */
		}
	}
	
	.quoting { 
		font-size: 0.8rem; 
		opacity: 0.7;
		font-style: italic;
	}


	
	.faq { 
		padding: 3rem 0; 
	}
	
	/* Le parent Accordéon */
	details.faq-parent { 
		margin-bottom: 1rem; 
		overflow: hidden; 
		border-radius: 0.5rem;
		text-align: left;
	}

	summary { 
		padding: 1rem 1.5rem; 
		cursor: pointer; 
		font-weight: bold; 
		transition: background-color 0.3s; 
		color: var(--dark-purple); /* Texte sombre lisible */
		list-style: none;
	}
	summary::-webkit-details-marker { display: none; } /* Enleve la flèche native */
	summary::after { content: "+"; float: right; }
	details[open] > summary::after { content: "−"; }

	details.faq-parent p, 
	details.faq-parent ul, 
	details.faq-parent h3 { 
		padding: 0.5rem 1.5rem; 
		color: var(--dark-purple) !important; /* Force l'écriture en couleur lisible */
	}

	details.faq-parent a {
		color: var(--deep-blue);
	}


	details.faq-parent ul {
		margin-left: 3rem;
		margin-bottom: 1rem;
	}

	.faq-child { 
		margin-left: 1.5rem; 
		margin-top: 0.5rem; 
		border-radius: 0.25rem;
	}
	.faq-child > summary { font-size: 0.95rem; font-weight: 600; }
</style>
